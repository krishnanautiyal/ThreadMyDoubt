generator client {
 provider = "prisma-client-js"
}

datasource db {
 provider = "postgresql"
}

model User {
 id         String   @id
 username   String
 email      String   @unique
 password   String
 role       String?
 bio        String?
 reputation Int      @default(0)
 profilePicture String?
 createdAt  DateTime @default(now())
}